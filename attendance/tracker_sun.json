    {
      "parameters": {
        "jsCode": "// ─── Log Timestamps — inserted between Parse EXIF and Within 2 Minutes? ──────\nconst exif = items[0].json;\n\nconst locationTs  = Number($('Lookup Pending Checkin').item.json.location_timestamp);\nconst messageDate = Number($('Telegram Trigger').item.json.message.date);\nconst exifTs      = exif.exifFound ? Number(exif.exifDateTimeOriginal) : null;\n\nconst usedTs = exif.exifFound ? exifTs : messageDate;\nconst diff   = Math.abs(usedTs - locationTs);\nconst willPass = diff <= 120;\n\nconst log = [\n  '─── Timestamp Comparison ───────────────────────────',\n  `📍 location_timestamp (from Sheets) : ${locationTs}  → ${new Date(locationTs * 1000).toISOString()}`,\n  `📨 message.date (Telegram received) : ${messageDate} → ${new Date(messageDate * 1000).toISOString()}`,\n  `📸 EXIF DateTimeOriginal            : ${exifTs !== null ? exifTs + '  → ' + new Date(exifTs * 1000).toISOString() : 'N/A (no EXIF)'}`,\n  '',\n  `🔀 Using timestamp                  : ${exif.exifFound ? 'EXIF' : 'message.date (fallback)'}`,\n  `⏱️  Difference                       : ${diff} seconds`,\n  `${willPass ? '✅' : '❌'} Within 2 minutes?               : ${willPass ? 'YES — will proceed' : 'NO — will reject'}`,\n  '────────────────────────────────────────────────────'\n].join('\\n');\n\nreturn [{ json: { ...exif, locationTs, messageDate, exifTs, diff, willPass, timestamp_log: log } }];"
      },
