    {
      "parameters": {
        "jsCode": "// ─── STEP 1: Validate binary input ───────────────────────────────────────────\nif (!items[0].binary || Object.keys(items[0].binary).length === 0) {\n  return [{ json: {\n    exifFound: false,\n    exifDateTimeOriginal: null,\n    exifGpsLat: null,\n    exifGpsLng: null,\n    fileType: 'no_binary',\n    note: 'No binary data received from Download Document node',\n    log: '❌ Binary is empty — Download Document node may have failed silently'\n  }}];\n}\n\nconst binaryKey = Object.keys(items[0].binary)[0];\nconst buffer = Buffer.from(items[0].binary[binaryKey].data, 'base64');\nconst magicHex = buffer.slice(0, 4).toString('hex');\nconst magicBytes = [buffer[0], buffer[1], buffer[2], buffer[3]];\n\n// ─── STEP 2: Detect file type from magic bytes ────────────────────────────────\nconst isJPEG = buffer[0] === 0xFF && buffer[1] === 0xD8;\nconst isPNG  = buffer[0] === 0x89 && buffer[1] === 0x50 && buffer[2] === 0x4E && buffer[3] === 0x47;\nconst isHEIC = buffer.slice(4, 8).toString('ascii') === 'ftyp';\nconst isWEBP = buffer.slice(0, 4).toString('ascii') === 'RIFF' && buffer.slice(8, 12).toString('ascii') === 'WEBP';\n\nlet fileType = isJPEG ? 'JPEG' : isPNG ? 'PNG' : isHEIC ? 'HEIC' : isWEBP ? 'WEBP' : 'unknown';\n\nconst baseLog = [\n  `📁 Binary field name: \"${binaryKey}\"`,\n  `📦 Buffer size: ${buffer.length} bytes`,\n  `🔢 Magic bytes: ${magicHex} → detected as ${fileType}`,\n  `🔢 Raw first bytes: [${magicBytes.join(', ')}]`\n];\n\nif (!isJPEG) {\n  return [{ json: {\n    exifFound: false,\n    exifDateTimeOriginal: null,\n    exifGpsLat: null,\n    exifGpsLng: null,\n    fileType,\n    note: `${fileType} detected — EXIF not parsed, will use message.date fallback`,\n    log: baseLog.join('\\n') + `\\n⚠️ Not a JPEG — skipping EXIF parse, fallback to message.date`\n  }}];\n}\n\n// ─── STEP 3: Parse EXIF (JPEG only) ──────────────────────────────────────────\nlet result = {\n  exifFound: false,\n  exifDateTimeOriginal: null,\n  exifGpsLat: null,\n  exifGpsLng: null,\n  fileType: 'JPEG'\n};\nconst logs = [...baseLog];\n\nfunction readUInt16(buf, offset, le) {\n  return le ? buf[offset] | (buf[offset+1]<<8) : (buf[offset]<<8) | buf[offset+1];\n}\nfunction readUInt32(buf, offset, le) {\n  return le\n    ? buf[offset] | (buf[offset+1]<<8) | (buf[offset+2]<<16) | (buf[offset+3]<<24)\n    : (buf[offset]<<24) | (buf[offset+1]<<16) | (buf[offset+2]<<8) | buf[offset+3];\n}\nfunction readRational(buf, offset, le) {\n  const num = readUInt32(buf, offset, le);\n  const den = readUInt32(buf, offset+4, le);\n  return den !== 0 ? num/den : 0;\n}\nfunction readString(buf, offset, length) {\n  return buf.slice(offset, offset+length).toString('ascii').replace(/\\0/g,'').trim();\n}\n\ntry {\n  let offset = 2, app1Offset = -1;\n  while (offset < buffer.length - 1) {\n    if (buffer[offset] === 0xFF && buffer[offset+1] === 0xE1) {\n      app1Offset = offset;\n      logs.push(`✅ APP1 segment found at offset ${offset}`);\n      break;\n    }\n    if (buffer[offset] === 0xFF && buffer[offset+1] !== 0xFF) {\n      const segLen = readUInt16(buffer, offset+2, false);\n      offset += 2 + segLen;\n    } else { offset++; }\n  }\n\n  if (app1Offset === -1) {\n    logs.push('⚠️ No APP1/EXIF segment found in JPEG — photo likely has no EXIF metadata (stripped by Telegram or camera)');\n    return [{ json: { ...result, note: 'No EXIF segment — using message.date fallback', log: logs.join('\\n') } }];\n  }\n\n  const exifHeader = buffer.slice(app1Offset+4, app1Offset+10).toString('ascii');\n  logs.push(`🔍 APP1 header: \"${exifHeader}\"`);\n\n  if (!exifHeader.startsWith('Exif')) {\n    logs.push('⚠️ APP1 segment exists but is not EXIF (maybe XMP)');\n    return [{ json: { ...result, note: 'APP1 not EXIF — using message.date fallback', log: logs.join('\\n') } }];\n  }\n\n  const exifStart = app1Offset + 10;\n  const byteOrder = buffer.slice(exifStart, exifStart+2).toString('ascii');\n  const le = byteOrder === 'II';\n  logs.push(`🔄 Byte order: ${byteOrder} (${le ? 'little-endian' : 'big-endian'})`);\n\n  const ifd0Offset = exifStart + readUInt32(buffer, exifStart+4, le);\n  const ifd0Count = readUInt16(buffer, ifd0Offset, le);\n  logs.push(`📋 IFD0 entries: ${ifd0Count}`);\n\n  let exifIFDOffset = -1, gpsIFDOffset = -1;\n  for (let i = 0; i < ifd0Count; i++) {\n    const e = ifd0Offset + 2 + i*12;\n    const tag = readUInt16(buffer, e, le);\n    if (tag === 0x8769) { exifIFDOffset = exifStart + readUInt32(buffer, e+8, le); logs.push('✅ ExifIFD pointer found'); }\n    if (tag === 0x8825) { gpsIFDOffset  = exifStart + readUInt32(buffer, e+8, le); logs.push('✅ GPS IFD pointer found'); }\n  }\n\n  if (exifIFDOffset === -1) logs.push('⚠️ No ExifIFD found — no DateTimeOriginal available');\n  if (gpsIFDOffset  === -1) logs.push('⚠️ No GPS IFD found — no GPS coords in EXIF');\n\n  if (exifIFDOffset !== -1) {\n    const exifCount = readUInt16(buffer, exifIFDOffset, le);\n    for (let i = 0; i < exifCount; i++) {\n      const e = exifIFDOffset + 2 + i*12;\n      const tag = readUInt16(buffer, e, le);\n      if (tag === 0x9003) {\n        const valOffset = exifStart + readUInt32(buffer, e+8, le);\n        const dtStr = readString(buffer, valOffset, 19);\n        logs.push(`📅 Raw EXIF DateTimeOriginal string: \"${dtStr}\"`);\n        const [datePart, timePart] = dtStr.split(' ');\n        const [y, mo, d] = datePart.split(':');\n        const [h, mi, s] = timePart.split(':');\n        const dt = new Date(Date.UTC(+y, +mo-1, +d, +h, +mi, +s));\n        const istOffsetMs = 5.5 * 60 * 60 * 1000;\n        result.exifDateTimeOriginal = Math.floor((dt.getTime() - istOffsetMs) / 1000);\n        result.exifFound = true;\n        logs.push(`🕐 EXIF time (parsed as IST→UTC Unix): ${result.exifDateTimeOriginal} = ${new Date(result.exifDateTimeOriginal * 1000).toISOString()}`);\n      }\n    }\n    if (!result.exifFound) logs.push('⚠️ ExifIFD found but tag 0x9003 (DateTimeOriginal) missing');\n  }\n\n  if (gpsIFDOffset !== -1) {\n    const gpsCount = readUInt16(buffer, gpsIFDOffset, le);\n    let latRef='N', lngRef='E', latVal=null, lngVal=null;\n    for (let i = 0; i < gpsCount; i++) {\n      const e = gpsIFDOffset + 2 + i*12;\n      const tag = readUInt16(buffer, e, le);\n      const count = readUInt32(buffer, e+4, le);\n      const valOffset = exifStart + readUInt32(buffer, e+8, le);\n      if (tag === 0x0001) latRef = String.fromCharCode(buffer[e+8]);\n      if (tag === 0x0003) lngRef = String.fromCharCode(buffer[e+8]);\n      if (tag === 0x0002 && count === 3) {\n        latVal = readRational(buffer,valOffset,le) + readRational(buffer,valOffset+8,le)/60 + readRational(buffer,valOffset+16,le)/3600;\n      }\n      if (tag === 0x0004 && count === 3) {\n        lngVal = readRational(buffer,valOffset,le) + readRational(buffer,valOffset+8,le)/60 + readRational(buffer,valOffset+16,le)/3600;\n      }\n    }\n    if (latVal !== null) { result.exifGpsLat = latRef==='S' ? -latVal : latVal; logs.push(`📍 EXIF GPS Lat: ${result.exifGpsLat}`); }\n    if (lngVal !== null) { result.exifGpsLng = lngRef==='W' ? -lngVal : lngVal; logs.push(`📍 EXIF GPS Lng: ${result.exifGpsLng}`); }\n    if (latVal === null && lngVal === null) logs.push('⚠️ GPS IFD found but no lat/lng values');\n  }\n\n} catch(e) {\n  logs.push(`❌ EXIF parse error: ${e.message}`);\n  result.error = e.message;\n}\n\nresult.log = logs.join('\\n');\nreturn [{ json: result }];"
      },
